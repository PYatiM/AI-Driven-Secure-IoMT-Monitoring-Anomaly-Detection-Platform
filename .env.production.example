APP_NAME=AI-Driven Secure IoMT Monitoring Anomaly Detection Platform
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1

DB_HOST=postgres
DB_PORT=5432
DB_NAME=iomt_platform
DB_USER=postgres
DB_PASSWORD=change-me
DB_ECHO=false

JWT_SECRET_KEY=replace-with-strong-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60
DEVICE_TOKEN_SECRET_KEY=replace-with-strong-device-token-secret
DEVICE_TOKEN_ALGORITHM=HS256
DEVICE_TOKEN_EXPIRES_MINUTES=15
DATA_ENCRYPTION_KEY=replace-with-strong-data-encryption-key

SECURE_KEY_STORAGE_ENABLED=true
SECURE_KEY_STORAGE_PATH=backend/secure/key_store.enc
KEY_STORAGE_MASTER_KEY=replace-with-strong-master-key
KEY_STORAGE_ALLOW_ENV_FALLBACK=false

HTTPS_ENFORCED=true
HTTPS_REDIRECT_STATUS_CODE=307
HTTPS_HSTS_ENABLED=true
HTTPS_HSTS_MAX_AGE=31536000
HTTPS_HSTS_INCLUDE_SUBDOMAINS=true
HTTPS_HSTS_PRELOAD=false

FIREWALL_ENABLED=true
FIREWALL_MODE=enforce
FIREWALL_CONFIG_PATH=infra/firewall/rules.json
FIREWALL_DEFAULT_ACTION=deny

AUDIT_LOGGING_ENABLED=true
SECURITY_EVENT_LOGGING_ENABLED=true
ALERT_ESCALATION_ENABLED=true
ALERT_ESCALATION_TARGET=security-operations

TELEMETRY_BATCH_MAX_RECORDS=1000
TELEMETRY_QUEUE_ENABLED=true
TELEMETRY_QUEUE_BATCH_SIZE=250
TELEMETRY_QUEUE_FLUSH_INTERVAL_MS=1000

AI_MODEL_ENABLED=false
AI_MODEL_PATH=
AI_MODEL_REGISTRY_PATH=ai/artifacts/model_registry.json
AI_PREDICTION_LOG_PATH=ai/logs/model_predictions.jsonl
AI_MONITORING_METRICS_PATH=ai/monitoring/model_performance.json

INTRUSION_DETECTION_ENABLED=true
INTRUSION_SCORE_THRESHOLD=0.72
INTRUSION_ANOMALY_SCORE_THRESHOLD=0.65
INTRUSION_CONFIDENCE_THRESHOLD=0.70

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

